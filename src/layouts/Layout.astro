---
/**
 * Base layout for msubaseballstats.com.
 *
 * Props:
 *   title       - page title shown in the browser tab
 *   description - optional meta description for SEO
 *   wide        - if true, content area expands to max-w-7xl (for wide stat tables)
 *
 * Theme:
 *   MSState Maroon  #5D1725  — nav bar background, active link indicators
 *   Light Grey      #C1C6C8  — borders, muted elements
 *   Dark Grey       #777777  — secondary/inactive text
 *   White           #FFFFFF  — page background (light mode), text on maroon
 *   Black           #000000  — body text (light mode)
 *
 * Dark mode: toggled by adding/removing the `dark` class on <html>.
 * Preference is persisted in localStorage. System preference is respected
 * when no explicit preference has been saved.
 */
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
}

const {
  title,
  description = "Mississippi State Baseball Statistics — advanced stats, splits, and situational analysis for the 2026 season.",
  wide = false,
} = Astro.props;

/* Used to highlight the active nav link */
const path = Astro.url.pathname;

/**
 * Returns true if the given href matches the current page path.
 * "/" only matches exactly to avoid highlighting Home on every page.
 */
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);

/** A simple single-page nav link */
type SimpleLink = { kind: "link"; href: string; label: string };

/**
 * A dropdown nav item — renders a hover menu with sub-pages.
 * basePath is used to determine if any sub-page is currently active.
 */
type DropdownLink = {
  kind: "dropdown";
  label: string;
  basePath: string;
  items: { href: string; label: string }[];
};

type NavItem = SimpleLink | DropdownLink;

const navItems: NavItem[] = [
  { kind: "link", href: "/", label: "Home" },
  {
    kind: "dropdown",
    label: "",
    basePath: "/",
    items: [
      { href: "/batting-2026", label: "Hitting Stats" },
      { href: "/pitching-2026", label: "Pitching Stats" },
      { href: "/fielding-2026", label: "Fielding Stats" },
      { href: "/situational-hitting-2026", label: "Situational Hitting" },
      { href: "/situational-pitching-2026", label: "Situational Pitching" },
      { href: "/batter-splits-2026", label: "Batter Splits Selector" },
      { href: "/pitcher-splits-2026", label: "Pitcher Splits Selector" },
      {
        href: "https://diamond-dawg-tracker.streamlit.app/",
        label: "Diamond Dawg Tracker",
      },
      { href: "/amegy-batters-2026", label: "Amegy Series — Batters" },
      { href: "/amegy-pitchers-2026", label: "Amegy Series — Pitchers" },
    ],
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title} | MSU Baseball Stats</title>

    <!--
      Theme init: runs synchronously before first paint to prevent
      a flash of the wrong theme (FOUC).
    -->
    <script is:inline>
      (function () {
        const saved = localStorage.getItem("theme");
        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;
        if (saved === "dark" || (!saved && prefersDark)) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>

    <style is:global>
      /* Hamburger slide-down menu */
      #nav-menu {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background-color: #5d1725;
        border-top: 1px solid #3d0f18;
        border-bottom: 1px solid #3d0f18;
        z-index: 40;
        padding: 0.5rem 0;
      }

      #nav-menu.open {
        display: block;
      }

      /* Section label inside menu */
      .menu-section-label {
        padding: 0.5rem 1.25rem 0.25rem;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #777777;
      }

      /* Individual menu link */
      .menu-link {
        display: block;
        padding: 0.55rem 1.25rem;
        font-size: 0.9rem;
        color: #c1c6c8;
        text-decoration: none;
        transition:
          background-color 0.1s,
          color 0.1s;
      }

      .menu-link:hover {
        background-color: rgba(255, 255, 255, 0.1);
        color: #ffffff;
        text-decoration: none;
      }

      .menu-link.active {
        color: #ffffff;
        font-weight: 600;
        background-color: rgba(255, 255, 255, 0.12);
      }

      /* Hamburger bar animation */
      #hamburger-btn .bar {
        display: block;
        width: 22px;
        height: 2px;
        background-color: #c1c6c8;
        transition:
          transform 0.2s,
          opacity 0.2s;
        transform-origin: center;
      }

      #hamburger-btn.open .bar:nth-child(1) {
        transform: translateY(8px) rotate(45deg);
        background-color: #ffffff;
      }

      #hamburger-btn.open .bar:nth-child(2) {
        opacity: 0;
      }

      #hamburger-btn.open .bar:nth-child(3) {
        transform: translateY(-8px) rotate(-45deg);
        background-color: #ffffff;
      }
    </style>
  </head>

  <body
    class="min-h-screen flex flex-col"
    style="background-color: var(--color-bg); color: var(--color-text);"
  >
    <!-- Sticky top nav — MSState Maroon background -->
    <header
      class="sticky top-0 z-50"
      style="background-color: #5D1725; border-bottom: 1px solid #3d0f18; position: relative;"
    >
      <div
        class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between"
      >
        <!-- Left: Hamburger button -->
        <button
          id="hamburger-btn"
          aria-label="Toggle navigation menu"
          aria-expanded="false"
          style="background: none; border: none; cursor: pointer; display: flex; flex-direction: column; justify-content: center; gap: 6px; padding: 4px; border-radius: 4px;"
        >
          <span class="bar"></span>
          <span class="bar"></span>
          <span class="bar"></span>
        </button>

        <!-- Center: Site name -->
        <a
          href="/"
          style="color: #ffffff; text-decoration: none; font-size: 1rem; font-weight: 700; letter-spacing: -0.01em; position: absolute; left: 50%; transform: translateX(-50%);"
        >
          MSU Baseball Stats
        </a>

        <!-- Right: Dark mode toggle -->
        <button
          id="theme-toggle"
          aria-label="Toggle dark mode"
          style="padding: 0.375rem; border-radius: 0.5rem; color: #C1C6C8; background: none; border: none; cursor: pointer; transition: color 0.15s, background-color 0.15s;"
          onmouseover="this.style.color='#ffffff'; this.style.backgroundColor='rgba(255,255,255,0.1)';"
          onmouseout="this.style.color='#C1C6C8'; this.style.backgroundColor='transparent';"
        >
          <svg
            id="moon-icon"
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
            ></path>
          </svg>
          <svg
            id="sun-icon"
            class="w-4 h-4 hidden"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"
            ></path>
          </svg>
        </button>
      </div>

      <!-- Slide-down nav menu -->
      <nav id="nav-menu" aria-label="Main navigation">
        {
          navItems.map((item) =>
            item.kind === "link" ? (
              <a
                href={item.href}
                class={`menu-link ${isActive(item.href) ? "active" : ""}`}
                aria-current={isActive(item.href) ? "page" : undefined}
              >
                {item.label}
              </a>
            ) : (
              <>
                {item.label && <div class="menu-section-label">{item.label}</div>}
                {item.items.map((sub) => (
                  <a
                    href={sub.href}
                    class={`menu-link ${isActive(sub.href) ? "active" : ""}`}
                    style="padding-left: 1.75rem;"
                    target={sub.href.startsWith("http") ? "_blank" : undefined}
                    rel={
                      sub.href.startsWith("http")
                        ? "noopener noreferrer"
                        : undefined
                    }
                  >
                    {sub.label}
                    {sub.href.startsWith("http") ? " ↗" : ""}
                  </a>
                ))}
              </>
            ),
          )
        }
      </nav>
    </header>

    <!-- Page content -->
    <main
      class={`flex-1 ${wide ? "max-w-7xl" : "max-w-5xl"} mx-auto w-full px-5 py-10`}
    >
      <slot />
    </main>

    <!-- Footer -->
    <footer
      style="border-top: 1px solid var(--color-light-grey, #C1C6C8); margin-top: auto;"
    >
      <div
        class="max-w-5xl mx-auto px-5 py-5 text-sm flex flex-wrap gap-x-4 justify-between"
        style="color: #777777;"
      >
        <span>msubaseballstats.com</span>
        <span
          >Data source: <a
            href="https://stats.ncaa.org/teams/614666"
            target="_blank"
            rel="noopener noreferrer"
            style="color: #777777; text-decoration: underline;">NCAA Stats</a
          ></span
        >
        <span
          >Built with <a
            href="https://astro.build"
            target="_blank"
            rel="noopener noreferrer"
            style="color: #777777; text-decoration: underline;">Astro</a
          ></span
        >
      </div>
    </footer>
  </body>
</html>

<script>
  /**
   * Dark mode toggle — syncs moon/sun icon with current theme.
   */
  const root = document.documentElement;
  const moonIcon = document.getElementById("moon-icon");
  const sunIcon = document.getElementById("sun-icon");

  function syncIcons() {
    const isDark = root.classList.contains("dark");
    moonIcon?.classList.toggle("hidden", isDark);
    sunIcon?.classList.toggle("hidden", !isDark);
  }

  syncIcons();

  document.getElementById("theme-toggle")?.addEventListener("click", () => {
    const nowDark = root.classList.toggle("dark");
    localStorage.setItem("theme", nowDark ? "dark" : "light");
    syncIcons();
  });

  /**
   * Hamburger menu toggle.
   * Clicking the button opens/closes the slide-down nav panel.
   * Clicking anywhere outside the header closes it.
   * Clicking a nav link closes it too.
   */
  const hamburger = document.getElementById(
    "hamburger-btn",
  ) as HTMLButtonElement;
  const navMenu = document.getElementById("nav-menu") as HTMLElement;

  function closeMenu() {
    navMenu.classList.remove("open");
    hamburger.classList.remove("open");
    hamburger.setAttribute("aria-expanded", "false");
  }

  hamburger?.addEventListener("click", (e) => {
    e.stopPropagation();
    const isOpen = navMenu.classList.toggle("open");
    hamburger.classList.toggle("open", isOpen);
    hamburger.setAttribute("aria-expanded", String(isOpen));
  });

  // Close when clicking a menu link
  navMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", closeMenu);
  });

  // Close when clicking outside
  document.addEventListener("click", (e) => {
    if (
      !hamburger.contains(e.target as Node) &&
      !navMenu.contains(e.target as Node)
    ) {
      closeMenu();
    }
  });
</script>
