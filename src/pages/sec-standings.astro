---
/**
 * SEC Standings page for msubaseballstats.com.
 *
 * Displays the current SEC baseball standings table, fetched client-side
 * from /data/sec-standings-2026.json (scraped from secsports.com).
 *
 * Features:
 *   - Sortable columns (click any header to sort asc/desc)
 *   - Mississippi State row highlighted in MSState Maroon
 *   - Alternating row shading
 *   - Vertical column dividers
 *   - Streak column color-coded (W = green, L = red)
 */
import Layout from '../layouts/Layout.astro';
---

<Layout title="SEC Standings" description="2026 SEC baseball standings.">

  <div class="max-w-3xl mx-auto">

    <h1 class="text-2xl font-bold mb-1" style="color: #5D1725;">SEC Standings</h1>
    <p id="last-updated" class="text-sm mb-6" style="color: #777777;">Loading...</p>

    <div id="standings-container" class="table-wrap">
      <table id="standings-table">
        <thead>
          <tr id="header-row"></tr>
        </thead>
        <tbody id="standings-body"></tbody>
      </table>
    </div>

    <p class="text-xs mt-4" style="color: #777777;">
      Source: <a href="https://www.secsports.com/standings/baseball" target="_blank" rel="noopener noreferrer" style="color:#777777;text-decoration:underline;">SEC Sports</a>.
      Click any column header to sort.
    </p>

  </div>

</Layout>

<style>
  /* ---- Outer wrapper ---- */
  .table-wrap {
    overflow-x: auto;
    border: 1px solid #C1C6C8;
    border-radius: 0.375rem;
  }

  :where(.dark) .table-wrap {
    border-color: #3a3a3a;
  }

  /* ---- Table reset ---- */
  #standings-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
    white-space: nowrap;
    table-layout: auto;
  }

  /* ---- Header ---- */
  #standings-table thead {
    background-color: #5D1725;
    color: #ffffff;
  }

  #standings-table thead th {
    padding: 0.6rem 0.85rem;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-align: center;
    cursor: pointer;
    user-select: none;
    border-right: 1px solid rgba(255, 255, 255, 0.18);
    white-space: nowrap;
  }

  #standings-table thead th:last-child {
    border-right: none;
  }

  /* Team name: left-aligned */
  #standings-table thead th:first-child {
    text-align: left;
    min-width: 9.5rem;
  }

  /* Sort indicator — appended by JS */
  #standings-table thead th .sort-icon {
    display: inline-block;
    margin-left: 0.3rem;
    font-size: 0.65rem;
    opacity: 0.55;
  }

  #standings-table thead th.sort-asc .sort-icon,
  #standings-table thead th.sort-desc .sort-icon {
    opacity: 1;
  }

  #standings-table thead th:hover {
    background-color: rgba(255, 255, 255, 0.1);
  }

  /* ---- Body rows ---- */
  #standings-table tbody tr {
    border-bottom: 1px solid #C1C6C8;
  }

  :where(.dark) #standings-table tbody tr {
    border-color: #2e2e2e;
  }

  #standings-table tbody tr:last-child {
    border-bottom: none;
  }

  /* Alternating row shading — light mode */
  #standings-table tbody tr:nth-child(odd) {
    background-color: #ffffff;
  }

  #standings-table tbody tr:nth-child(even) {
    background-color: #f3f3f4;
  }

  /* Alternating row shading — dark mode */
  :where(.dark) #standings-table tbody tr:nth-child(odd) {
    background-color: #0d0608;
  }

  :where(.dark) #standings-table tbody tr:nth-child(even) {
    background-color: #1a1014;
  }

  /* ---- Body cells ---- */
  #standings-table tbody td {
    padding: 0.5rem 0.85rem;
    text-align: center;
    border-right: 1px solid #C1C6C8;
    color: var(--color-text);
  }

  :where(.dark) #standings-table tbody td {
    border-color: #2e2e2e;
  }

  #standings-table tbody td:last-child {
    border-right: none;
  }

  /* Team name cell: left-aligned */
  #standings-table tbody td:first-child {
    text-align: left;
    font-weight: 500;
  }

  /* ---- MSU highlight row ---- */
  #standings-table tbody tr.msu-row,
  #standings-table tbody tr.msu-row:nth-child(odd),
  #standings-table tbody tr.msu-row:nth-child(even) {
    background-color: #5D1725 !important;
  }

  #standings-table tbody tr.msu-row td {
    color: #ffffff;
    font-weight: 600;
    border-right-color: rgba(255, 255, 255, 0.18);
  }

  /* ---- Streak coloring ---- */
  .strk-win  { color: #16a34a; font-weight: 700; }
  .strk-loss { color: #dc2626; font-weight: 700; }

  :where(.dark) .strk-win  { color: #4ade80; }
  :where(.dark) .strk-loss { color: #f87171; }

  /* MSU row: keep streak white regardless */
  .msu-row .strk-win,
  .msu-row .strk-loss { color: #ffffff; }
</style>

<script>
  /**
   * Fetch standings JSON, render the table, and wire up column sorting.
   *
   * Sort state:
   *   - First click on a numeric column → sort descending (best first)
   *   - First click on Team column → sort ascending (A→Z)
   *   - Second click on same column → reverse direction
   *   - Third click → return to original order
   */

  // Original row order preserved for "third click" reset
  let originalTeams: string[][] = [];
  let allColumns: string[]      = [];

  // Sort state: { colIdx: number, dir: 'asc' | 'desc' | 'none' }
  let sortState = { colIdx: -1, dir: 'none' as 'asc' | 'desc' | 'none' };

  async function loadStandings() {
    try {
      const res = await fetch('/data/sec-standings-2026.json');
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();

      allColumns    = data.columns;
      originalTeams = data.teams.map((r: string[]) => [...r]); // deep copy

      /* ---- Last updated ---- */
      const updatedEl = document.getElementById('last-updated');
      if (updatedEl && data.lastUpdated) {
        const d = new Date(data.lastUpdated);
        updatedEl.textContent = `Last updated ${d.toLocaleDateString('en-US', {
          month: 'long', day: 'numeric', year: 'numeric',
          hour: 'numeric', minute: '2-digit',
        })}`;
      }

      /* ---- Header row ---- */
      const headerRow = document.getElementById('header-row')!;
      allColumns.forEach((label, i) => {
        const th = document.createElement('th');
        th.dataset.colIdx = String(i);

        const labelSpan = document.createElement('span');
        labelSpan.textContent = label;

        const iconSpan = document.createElement('span');
        iconSpan.className = 'sort-icon';
        iconSpan.textContent = '⇅';

        th.appendChild(labelSpan);
        th.appendChild(iconSpan);
        th.addEventListener('click', () => onHeaderClick(i));
        headerRow.appendChild(th);
      });

      /* ---- Initial render ---- */
      renderRows(originalTeams);

    } catch (err) {
      console.error('Standings load error:', err);
      const updated = document.getElementById('last-updated');
      if (updated) updated.textContent = 'Unable to load standings data.';
      const container = document.getElementById('standings-container');
      if (container) {
        container.innerHTML =
          '<p style="padding:1rem;color:#777">Standings data is unavailable. Please check back later.</p>';
      }
    }
  }

  /**
   * Handle a header click: cycle through asc → desc → original, then re-render.
   * Numeric columns default first-click to descending (highest value first).
   * The Team column defaults first-click to ascending (A → Z).
   */
  function onHeaderClick(colIdx: number) {
    const isTeamCol = colIdx === 0;

    if (sortState.colIdx !== colIdx) {
      // New column: first click
      sortState.colIdx = colIdx;
      sortState.dir    = isTeamCol ? 'asc' : 'desc';
    } else {
      // Same column: cycle
      if (sortState.dir === 'desc') sortState.dir = 'asc';
      else if (sortState.dir === 'asc') sortState.dir = 'none';
      else sortState.dir = isTeamCol ? 'asc' : 'desc';
    }

    // Update header visual state
    document.querySelectorAll('#header-row th').forEach((th) => {
      th.classList.remove('sort-asc', 'sort-desc');
      const icon = th.querySelector('.sort-icon') as HTMLElement;
      if (icon) icon.textContent = '⇅';
    });

    const activeTh = document.querySelector(
      `#header-row th[data-col-idx="${colIdx}"]`
    ) as HTMLElement;

    if (activeTh && sortState.dir !== 'none') {
      activeTh.classList.add(sortState.dir === 'asc' ? 'sort-asc' : 'sort-desc');
      const icon = activeTh.querySelector('.sort-icon') as HTMLElement;
      if (icon) icon.textContent = sortState.dir === 'asc' ? '▲' : '▼';
    }

    const sorted = getSortedTeams();
    renderRows(sorted);
  }

  /**
   * Return a sorted copy of the teams array based on current sortState.
   * Uses original order when dir === 'none'.
   */
  function getSortedTeams(): string[][] {
    if (sortState.dir === 'none') return [...originalTeams];

    const { colIdx, dir } = sortState;
    const multiplier      = dir === 'asc' ? 1 : -1;

    return [...originalTeams].sort((a, b) => {
      const av = a[colIdx];
      const bv = b[colIdx];

      // Numeric parse: handles "7-8" W-L strings (use wins), "0.467" pcts, "W1"/"L3" streaks
      const an = parseSortVal(av, colIdx);
      const bn = parseSortVal(bv, colIdx);

      if (an !== null && bn !== null) return (an - bn) * multiplier;
      return av.localeCompare(bv) * multiplier;
    });
  }

  /**
   * Convert a cell value to a number for sorting purposes.
   *
   * - W-L strings ("7-8", "27-10") → wins (first number)
   * - Streak strings ("W3", "L2")   → signed integer (W=positive, L=negative)
   * - Pct strings ("0.467")         → float
   * - Pure integers                 → int
   * Returns null if the value can't be parsed as a number.
   */
  function parseSortVal(val: string, colIdx: number): number | null {
    if (!val) return null;

    const label = allColumns[colIdx] || '';

    // W-L columns: sort by wins
    if (label.includes('W-L')) {
      const parts = val.split('-');
      if (parts.length === 2) return parseInt(parts[0], 10) || 0;
    }

    // Streak column: W1 → +1, L3 → -3
    if (label === 'Strk') {
      const sign = val[0] === 'W' ? 1 : -1;
      return sign * (parseInt(val.slice(1), 10) || 0);
    }

    // Try float
    const f = parseFloat(val);
    if (!isNaN(f)) return f;

    return null;
  }

  /**
   * Clear and re-render the tbody with the given rows.
   * MSU's row always gets the maroon highlight class.
   */
  function renderRows(teams: string[][]) {
    const tbody   = document.getElementById('standings-body')!;
    const strkIdx = allColumns.indexOf('Strk');
    tbody.innerHTML = '';

    for (const team of teams) {
      const tr = document.createElement('tr');

      const isMsu = (team[0] || '').toLowerCase().includes('mississippi state');
      if (isMsu) tr.classList.add('msu-row');

      team.forEach((cell, i) => {
        const td = document.createElement('td');

        if (i === strkIdx && cell) {
          const span = document.createElement('span');
          span.textContent = cell;
          span.classList.add(cell.startsWith('W') ? 'strk-win' : 'strk-loss');
          td.appendChild(span);
        } else {
          td.textContent = cell;
        }

        tr.appendChild(td);
      });

      tbody.appendChild(tr);
    }
  }

  loadStandings();
</script>
