---
/**
 * SEC Standings page for msubaseballstats.com.
 *
 * Displays the current SEC baseball standings table, fetched client-side
 * from /data/sec-standings-2026.json (scraped from secsports.com).
 *
 * Columns: Team | Conf W-L | Conf Pct | Overall W-L | Overall Pct |
 *          Home | Road | Neutral | Strk
 *
 * Mississippi State's row is highlighted in MSState Maroon.
 */
import Layout from '../layouts/Layout.astro';
---

<Layout title="SEC Standings" description="2026 SEC baseball standings.">

  <div class="max-w-3xl mx-auto">

    <h1 class="text-2xl font-bold mb-1" style="color: #5D1725;">SEC Standings</h1>
    <p id="last-updated" class="text-sm mb-6" style="color: #777777;">Loading...</p>

    <!-- Scrollable table wrapper -->
    <div id="standings-container" class="table-wrap">
      <table id="standings-table">
        <thead>
          <tr id="header-row"></tr>
        </thead>
        <tbody id="standings-body"></tbody>
      </table>
    </div>

    <p class="text-xs mt-4" style="color: #777777;">
      Source: <a href="https://www.secsports.com/standings/baseball" target="_blank" rel="noopener noreferrer">SEC Sports</a>
    </p>

  </div>

</Layout>

<style>
  /* ---- Table wrapper with horizontal scroll ---- */
  .table-wrap {
    overflow-x: auto;
    border: 1px solid var(--color-light-grey);
    border-radius: 0.375rem;
  }

  :where(.dark) .table-wrap {
    border-color: #333;
  }

  /* ---- Table base ---- */
  #standings-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
    white-space: nowrap;
  }

  /* ---- Header ---- */
  #standings-table thead tr {
    background-color: #5D1725;
    color: #ffffff;
  }

  #standings-table thead th {
    padding: 0.55rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-align: center;
  }

  /* Team name column: left-align */
  #standings-table thead th:first-child,
  #standings-table tbody td:first-child {
    text-align: left;
    min-width: 10rem;
  }

  /* ---- Body rows ---- */
  #standings-table tbody tr {
    border-bottom: 1px solid var(--color-light-grey);
  }

  :where(.dark) #standings-table tbody tr {
    border-color: #222;
  }

  #standings-table tbody tr:last-child {
    border-bottom: none;
  }

  #standings-table tbody td {
    padding: 0.5rem 0.75rem;
    text-align: center;
    color: var(--color-text);
  }

  /* Alternating row stripes */
  #standings-table tbody tr:nth-child(even) {
    background-color: rgba(0, 0, 0, 0.03);
  }

  :where(.dark) #standings-table tbody tr:nth-child(even) {
    background-color: rgba(255, 255, 255, 0.04);
  }

  /* ---- Mississippi State highlight row ---- */
  #standings-table tbody tr.msu-row {
    background-color: #5D1725 !important;
    color: #ffffff;
  }

  #standings-table tbody tr.msu-row td {
    color: #ffffff;
    font-weight: 600;
  }

  /* ---- Streak: color W green, L red ---- */
  .strk-win {
    color: #16a34a;
    font-weight: 700;
  }

  .strk-loss {
    color: #dc2626;
    font-weight: 700;
  }

  :where(.dark) .strk-win  { color: #4ade80; }
  :where(.dark) .strk-loss { color: #f87171; }

  /* MSU row streak — white text overrides color classes */
  .msu-row .strk-win,
  .msu-row .strk-loss {
    color: #ffffff;
  }
</style>

<script>
  /**
   * Fetch sec-standings-2026.json and render the standings table.
   * Mississippi State's row is given a maroon highlight class.
   */
  async function loadStandings() {
    try {
      const res = await fetch('/data/sec-standings-2026.json');
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();

      /* ---- Last updated line ---- */
      const updatedEl = document.getElementById('last-updated');
      if (updatedEl && data.lastUpdated) {
        const d = new Date(data.lastUpdated);
        const formatted = d.toLocaleDateString('en-US', {
          month: 'long', day: 'numeric', year: 'numeric',
          hour: 'numeric', minute: '2-digit',
        });
        updatedEl.textContent = `Last updated ${formatted}`;
      }

      /* ---- Header row ---- */
      const headerRow = document.getElementById('header-row')!;
      for (const col of data.columns) {
        const th = document.createElement('th');
        th.textContent = col;
        headerRow.appendChild(th);
      }

      /* ---- Team rows ---- */
      const tbody = document.getElementById('standings-body')!;
      const strkIdx = data.columns.indexOf('Strk');

      for (const team of data.teams) {
        const tr = document.createElement('tr');

        // Highlight the MSU row
        const teamName: string = team[0] || '';
        if (teamName.toLowerCase().includes('mississippi state')) {
          tr.classList.add('msu-row');
        }

        team.forEach((cell: string, i: number) => {
          const td = document.createElement('td');

          // Color-code the Strk column (W = green, L = red)
          if (i === strkIdx && cell) {
            const span = document.createElement('span');
            span.textContent = cell;
            span.classList.add(cell.startsWith('W') ? 'strk-win' : 'strk-loss');
            td.appendChild(span);
          } else {
            td.textContent = cell;
          }

          tr.appendChild(td);
        });

        tbody.appendChild(tr);
      }

    } catch (err) {
      console.error('Standings load error:', err);
      const updated = document.getElementById('last-updated');
      if (updated) updated.textContent = 'Unable to load standings data.';

      const container = document.getElementById('standings-container');
      if (container) {
        container.innerHTML = '<p style="padding:1rem;color:#777">Standings data is unavailable. Please check back later.</p>';
      }
    }
  }

  loadStandings();
</script>
