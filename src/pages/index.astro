---
/**
 * Home/dashboard page for msubaseballstats.com.
 *
 * Displays:
 *   - Current record (overall & SEC)
 *   - Team hitting stats (AVG / OBP / SLG)
 *   - Team pitching stats (ERA / WHIP / K-BB%)
 *   - Team leaders: HR, SB (hitters), IP, K (pitchers)
 *
 * Data is fetched client-side from the pre-scraped JSON files,
 * consistent with how all other stats pages work.
 */
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home" description="Mississippi State Baseball Statistics — advanced stats, splits, and situational analysis.">

  <!-- Last-updated line -->
  <p id="last-updated" class="text-sm text-center mb-6" style="color: var(--color-dark-grey);">
    Loading...
  </p>

  <!-- Dashboard grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-3xl mx-auto">

    <!-- Record card -->
    <div class="dash-card" id="card-record">
      <h2 class="dash-card-title">2026 Record</h2>
      <div class="dash-card-body">
        <div class="record-row">
          <span class="record-label">Overall</span>
          <span class="record-value" id="record-overall">--</span>
        </div>
        <div class="record-row">
          <span class="record-label">SEC</span>
          <span class="record-value" id="record-sec">--</span>
        </div>
      </div>
    </div>

    <!-- Team Hitting card -->
    <div class="dash-card" id="card-hitting">
      <h2 class="dash-card-title">Team Hitting</h2>
      <div class="dash-card-body stat-grid-3">
        <div class="stat-cell">
          <span class="stat-value" id="hit-avg">--</span>
          <span class="stat-label">AVG</span>
        </div>
        <div class="stat-cell">
          <span class="stat-value" id="hit-obp">--</span>
          <span class="stat-label">OBP</span>
        </div>
        <div class="stat-cell">
          <span class="stat-value" id="hit-slg">--</span>
          <span class="stat-label">SLG</span>
        </div>
      </div>
    </div>

    <!-- Team Pitching card -->
    <div class="dash-card" id="card-pitching">
      <h2 class="dash-card-title">Team Pitching</h2>
      <div class="dash-card-body stat-grid-3">
        <div class="stat-cell">
          <span class="stat-value" id="pit-era">--</span>
          <span class="stat-label">ERA</span>
        </div>
        <div class="stat-cell">
          <span class="stat-value" id="pit-whip">--</span>
          <span class="stat-label">WHIP</span>
        </div>
        <div class="stat-cell">
          <span class="stat-value" id="pit-kbb">--</span>
          <span class="stat-label">K-BB%</span>
        </div>
      </div>
    </div>

    <!-- Team Leaders card -->
    <div class="dash-card" id="card-leaders">
      <h2 class="dash-card-title">Team Leaders</h2>
      <div class="dash-card-body">
        <table class="leaders-table">
          <tbody>
            <tr>
              <td class="leader-cat">HR</td>
              <td class="leader-name" id="leader-hr-name">--</td>
              <td class="leader-val" id="leader-hr-val">--</td>
            </tr>
            <tr>
              <td class="leader-cat">SB</td>
              <td class="leader-name" id="leader-sb-name">--</td>
              <td class="leader-val" id="leader-sb-val">--</td>
            </tr>
            <tr>
              <td class="leader-cat">IP</td>
              <td class="leader-name" id="leader-ip-name">--</td>
              <td class="leader-val" id="leader-ip-val">--</td>
            </tr>
            <tr>
              <td class="leader-cat">K</td>
              <td class="leader-name" id="leader-k-name">--</td>
              <td class="leader-val" id="leader-k-val">--</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

  </div>

  <!-- Quick-links section -->
  <div class="max-w-3xl mx-auto mt-8">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      <a href="/batting" class="quick-link">Batting Stats</a>
      <a href="/pitching" class="quick-link">Pitching Stats</a>
      <a href="/batting-splits-tool" class="quick-link">Batting Splits</a>
      <a href="/pitching-splits-tool" class="quick-link">Pitching Splits</a>
    </div>
  </div>

</Layout>

<style>
  /* ---------- Dashboard card ---------- */
  .dash-card {
    border: 1px solid var(--color-light-grey);
    border-radius: 0.5rem;
    overflow: hidden;
  }

  :where(.dark) .dash-card {
    border-color: #333;
  }

  .dash-card-title {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.6rem 1rem;
    margin: 0;
    background-color: #5D1725;
    color: #ffffff;
  }

  .dash-card-body {
    padding: 1.25rem 1rem;
  }

  /* ---------- Record card ---------- */
  .record-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.3rem 0;
  }

  .record-row + .record-row {
    border-top: 1px solid var(--color-light-grey);
  }

  :where(.dark) .record-row + .record-row {
    border-color: #333;
  }

  .record-label {
    font-size: 0.9rem;
    color: var(--color-dark-grey);
  }

  .record-value {
    font-size: 1.6rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  /* ---------- 3-column stat grid ---------- */
  .stat-grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    text-align: center;
    gap: 0.5rem;
  }

  .stat-cell {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .stat-value {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .stat-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-dark-grey);
  }

  /* ---------- Leaders table ---------- */
  .leaders-table {
    width: 100%;
    border-collapse: collapse;
  }

  .leaders-table tr + tr {
    border-top: 1px solid var(--color-light-grey);
  }

  :where(.dark) .leaders-table tr + tr {
    border-color: #333;
  }

  .leaders-table td {
    padding: 0.45rem 0;
  }

  .leader-cat {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #5D1725;
    width: 2.5rem;
  }

  :where(.dark) .leader-cat {
    color: #c45068;
  }

  .leader-name {
    font-size: 0.95rem;
    color: var(--color-text);
  }

  .leader-val {
    font-size: 1.1rem;
    font-weight: 700;
    text-align: right;
    color: var(--color-text);
  }

  /* ---------- Quick links ---------- */
  .quick-link {
    display: block;
    text-align: center;
    padding: 0.6rem 0.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    border: 1px solid var(--color-light-grey);
    border-radius: 0.375rem;
    color: var(--color-text) !important;
    text-decoration: none !important;
    transition: background-color 0.15s, border-color 0.15s;
  }

  .quick-link:hover {
    background-color: #5D1725;
    border-color: #5D1725;
    color: #ffffff !important;
  }

  :where(.dark) .quick-link {
    border-color: #333;
  }

  :where(.dark) .quick-link:hover {
    background-color: #5D1725;
    border-color: #5D1725;
  }
</style>

<script>
  /**
   * Fetches hitting and pitching JSON, then populates the dashboard cards.
   */
  async function loadDashboard() {
    try {
      const [hitRes, pitRes] = await Promise.all([
        fetch('/data/hitting-stats-2026.json'),
        fetch('/data/pitching-stats-2026.json'),
      ]);

      if (!hitRes.ok || !pitRes.ok) throw new Error('Failed to fetch stats data');

      const hitting = await hitRes.json();
      const pitching = await pitRes.json();

      /* ---- Last updated ---- */
      const updatedEl = document.getElementById('last-updated');
      if (updatedEl && hitting.lastUpdated) {
        const d = new Date(hitting.lastUpdated);
        const formatted = d.toLocaleDateString('en-US', {
          month: 'long', day: 'numeric', year: 'numeric',
        });
        const games = hitting.gamesScraped || '?';
        updatedEl.textContent = `Through ${games} games \u2014 Last updated ${formatted}`;
      }

      /* ---- Helpers ---- */
      const col = (columns: string[], name: string) => columns.indexOf(name);

      /* ---- Record (from pitching summary W-L) ---- */
      const pitCols = pitching.all.columns;
      const wlIdx = col(pitCols, 'W-L');
      const overallWL = pitching.all.summary[0][wlIdx];
      const secWL = pitching.sec.summary[0][wlIdx];
      setText('record-overall', overallWL);
      setText('record-sec', secWL);

      /* ---- Team Hitting ---- */
      const hitCols = hitting.all.columns;
      const hitSummary = hitting.all.summary[0];
      setText('hit-avg', hitSummary[col(hitCols, 'AVG')]);
      setText('hit-obp', hitSummary[col(hitCols, 'OBP')]);
      setText('hit-slg', hitSummary[col(hitCols, 'SLG')]);

      /* ---- Team Pitching ---- */
      const pitSummary = pitching.all.summary[0];
      setText('pit-era', pitSummary[col(pitCols, 'ERA')]);
      setText('pit-whip', pitSummary[col(pitCols, 'WHIP')]);
      setText('pit-kbb', pitSummary[col(pitCols, 'K%-BB%')]);

      /* ---- Team Leaders ---- */
      const hitters = hitting.all.players;
      const pitchers = pitching.all.players;

      // HR leader (among hitters)
      const hrIdx = col(hitCols, 'HR');
      const hrLeader = findMax(hitters, hrIdx, parseIntSafe);
      setText('leader-hr-name', hrLeader.name);
      setText('leader-hr-val', String(hrLeader.value));

      // SB leader (among hitters) — format is "SB-ATT", e.g. "10-12"
      const sbIdx = col(hitCols, 'SB-ATT');
      const sbLeader = findMax(hitters, sbIdx, (v: string) => {
        const parts = v.split('-');
        return parseInt(parts[0], 10) || 0;
      });
      setText('leader-sb-name', sbLeader.name);
      // Show stolen bases count, not the "SB-ATT" string
      setText('leader-sb-val', String(sbLeader.value));

      // IP leader (among pitchers)
      const ipIdx = col(pitCols, 'IP');
      const ipLeader = findMax(pitchers, ipIdx, parseFloatSafe);
      setText('leader-ip-name', ipLeader.name);
      setText('leader-ip-val', pitchers.find((p: string[]) => p[0] === ipLeader.name)?.[ipIdx] ?? '--');

      // K leader (among pitchers)
      const soIdx = col(pitCols, 'SO');
      const kLeader = findMax(pitchers, soIdx, parseIntSafe);
      setText('leader-k-name', kLeader.name);
      setText('leader-k-val', String(kLeader.value));

    } catch (err) {
      console.error('Dashboard load error:', err);
      const updatedEl = document.getElementById('last-updated');
      if (updatedEl) updatedEl.textContent = 'Unable to load dashboard data.';
    }
  }

  /** Set text content of an element by ID. */
  function setText(id: string, text: string) {
    const el = document.getElementById(id);
    if (el) el.textContent = text;
  }

  /** Parse an integer string, returning 0 for anything non-numeric. */
  function parseIntSafe(v: string): number {
    return parseInt(v, 10) || 0;
  }

  /** Parse a float string, returning 0 for anything non-numeric. */
  function parseFloatSafe(v: string): number {
    return parseFloat(v) || 0;
  }

  /**
   * Find the player with the max value in a given column.
   * parser converts the string cell value to a number for comparison.
   */
  function findMax(
    players: string[][],
    colIdx: number,
    parser: (v: string) => number,
  ): { name: string; value: number } {
    let bestName = '--';
    let bestVal = -Infinity;

    for (const row of players) {
      const parsed = parser(row[colIdx]);
      if (parsed > bestVal) {
        bestVal = parsed;
        bestName = row[0];
      }
    }

    return { name: bestName, value: bestVal === -Infinity ? 0 : bestVal };
  }

  loadDashboard();
</script>
