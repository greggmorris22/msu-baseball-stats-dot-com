---
/**
 * Home/dashboard page for msubaseballstats.com.
 *
 * Displays:
 *   - Dynamic "last updated" timestamp
 *   - Current record (overall & SEC)
 *   - Team hitting stats (AVG, OBP, SLG, HR, SB-SBA, R/G)
 *   - Team pitching stats (ERA, WHIP, K-BB%, Opp AVG, Opp OBP, Opp SLG)
 *   - Batting leaders (AVG, OBP, SLG, R, HR, SB — 6 rows)
 *   - Pitching leaders (IP, K-BB%, K, WHIP, ERA, FIP — 6 rows, rate stats min 10 IP)
 *
 * Data is fetched client-side from the pre-scraped JSON files,
 * consistent with how all other stats pages work.
 */
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home" description="Mississippi State Baseball Statistics — advanced stats, splits, and situational analysis.">

  <!-- Last-updated line -->
  <p id="last-updated" class="text-sm text-center mb-6" style="color: var(--color-dark-grey);">
    Loading...
  </p>

  <!-- Dashboard grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-3xl mx-auto">

    <!-- Next Game card -->
    <div class="dash-card" id="card-next-game">
      <h2 class="dash-card-title">Next Game</h2>
      <div class="dash-card-body">
        <div class="record-row">
          <span class="record-label">Date</span>
          <span class="record-value" id="next-date">--</span>
        </div>
        <div class="record-row">
          <span class="record-label">Opponent</span>
          <span class="record-value" id="next-opponent">--</span>
        </div>
        <div class="record-row">
          <span class="record-label">Location</span>
          <span class="record-value" id="next-location">--</span>
        </div>
      </div>
    </div>

    <!-- Record card -->
    <div class="dash-card" id="card-record">
      <h2 class="dash-card-title">2026 Record</h2>
      <div class="dash-card-body">
        <div class="record-row">
          <span class="record-label">Overall</span>
          <span class="record-value" id="record-overall">--</span>
        </div>
        <div class="record-row">
          <span class="record-label">SEC</span>
          <span class="record-value" id="record-sec">--</span>
        </div>
      </div>
    </div>

    <!-- Team Hitting card (3x2 grid) -->
    <div class="dash-card" id="card-hitting">
      <h2 class="dash-card-title">Team Hitting</h2>
      <div class="dash-card-body stat-grid-3x2">
        <div class="stat-cell">
          <span class="stat-value" id="hit-avg">--</span>
          <span class="stat-label">AVG</span>
        </div>
        <div class="stat-cell">
          <span class="stat-value" id="hit-obp">--</span>
          <span class="stat-label">OBP</span>
        </div>
        <div class="stat-cell">
          <span class="stat-value" id="hit-slg">--</span>
          <span class="stat-label">SLG</span>
        </div>
        <div class="stat-cell">
          <span class="stat-value" id="hit-hr">--</span>
          <span class="stat-label">HR</span>
        </div>
        <div class="stat-cell">
          <span class="stat-value" id="hit-sb">--</span>
          <span class="stat-label">SB-SBA</span>
        </div>
        <div class="stat-cell">
          <span class="stat-value" id="hit-rpg">--</span>
          <span class="stat-label">R/G</span>
        </div>
      </div>
    </div>

    <!-- Team Pitching card (3x2 grid) -->
    <div class="dash-card" id="card-pitching">
      <h2 class="dash-card-title">Team Pitching</h2>
      <div class="dash-card-body stat-grid-3x2">
        <div class="stat-cell">
          <span class="stat-value" id="pit-era">--</span>
          <span class="stat-label">ERA</span>
        </div>
        <div class="stat-cell">
          <span class="stat-value" id="pit-whip">--</span>
          <span class="stat-label">WHIP</span>
        </div>
        <div class="stat-cell">
          <span class="stat-value" id="pit-kbb">--</span>
          <span class="stat-label">K-BB%</span>
        </div>
        <div class="stat-cell">
          <span class="stat-value" id="pit-opp-avg">--</span>
          <span class="stat-label">Opp AVG</span>
        </div>
        <div class="stat-cell">
          <span class="stat-value" id="pit-opp-obp">--</span>
          <span class="stat-label">Opp OBP</span>
        </div>
        <div class="stat-cell">
          <span class="stat-value" id="pit-opp-slg">--</span>
          <span class="stat-label">Opp SLG</span>
        </div>
      </div>
    </div>

    <!-- Batting Leaders card (6 rows) -->
    <div class="dash-card" id="card-bat-leaders">
      <h2 class="dash-card-title">Batting Leaders</h2>
      <div class="dash-card-body">
        <table class="leaders-table">
          <tbody>
            <tr>
              <td class="leader-cat">AVG</td>
              <td class="leader-name" id="bldr-avg-name">--</td>
              <td class="leader-val" id="bldr-avg-val">--</td>
            </tr>
            <tr>
              <td class="leader-cat">OBP</td>
              <td class="leader-name" id="bldr-obp-name">--</td>
              <td class="leader-val" id="bldr-obp-val">--</td>
            </tr>
            <tr>
              <td class="leader-cat">SLG</td>
              <td class="leader-name" id="bldr-slg-name">--</td>
              <td class="leader-val" id="bldr-slg-val">--</td>
            </tr>
            <tr>
              <td class="leader-cat">R</td>
              <td class="leader-name" id="bldr-r-name">--</td>
              <td class="leader-val" id="bldr-r-val">--</td>
            </tr>
            <tr>
              <td class="leader-cat">HR</td>
              <td class="leader-name" id="bldr-hr-name">--</td>
              <td class="leader-val" id="bldr-hr-val">--</td>
            </tr>
            <tr>
              <td class="leader-cat">SB</td>
              <td class="leader-name" id="bldr-sb-name">--</td>
              <td class="leader-val" id="bldr-sb-val">--</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Pitching Leaders card (6 rows) -->
    <div class="dash-card" id="card-pit-leaders">
      <h2 class="dash-card-title">Pitching Leaders</h2>
      <div class="dash-card-body">
        <table class="leaders-table">
          <tbody>
            <tr>
              <td class="leader-cat">IP</td>
              <td class="leader-name" id="pldr-ip-name">--</td>
              <td class="leader-val" id="pldr-ip-val">--</td>
            </tr>
            <tr>
              <td class="leader-cat">K-BB%</td>
              <td class="leader-name" id="pldr-kbb-name">--</td>
              <td class="leader-val" id="pldr-kbb-val">--</td>
            </tr>
            <tr>
              <td class="leader-cat">K</td>
              <td class="leader-name" id="pldr-k-name">--</td>
              <td class="leader-val" id="pldr-k-val">--</td>
            </tr>
            <tr>
              <td class="leader-cat">WHIP</td>
              <td class="leader-name" id="pldr-whip-name">--</td>
              <td class="leader-val" id="pldr-whip-val">--</td>
            </tr>
            <tr>
              <td class="leader-cat">ERA</td>
              <td class="leader-name" id="pldr-era-name">--</td>
              <td class="leader-val" id="pldr-era-val">--</td>
            </tr>
            <tr>
              <td class="leader-cat">FIP</td>
              <td class="leader-name" id="pldr-fip-name">--</td>
              <td class="leader-val" id="pldr-fip-val">--</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

  </div>

</Layout>

<style is:global>
  /* ---------- Dashboard card ---------- */
  .dash-card {
    border: 1px solid var(--color-light-grey);
    border-radius: 0.5rem;
    overflow: hidden;
  }

  :where(.dark) .dash-card {
    border-color: #333;
  }

  .dash-card-title {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.6rem 1rem;
    margin: 0;
    background-color: #5D1725;
    color: #ffffff;
  }

  .dash-card-body {
    padding: 1.25rem 1rem;
  }

  /* ---------- Record card ---------- */
  .record-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.3rem 0;
  }

  .record-row + .record-row {
    border-top: 1px solid var(--color-light-grey);
  }

  :where(.dark) .record-row + .record-row {
    border-color: #333;
  }

  .record-label {
    font-size: 0.9rem;
    color: var(--color-dark-grey);
  }

  .record-value {
    font-size: 1.6rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  /* ---------- 3x2 stat grid ---------- */
  .stat-grid-3x2 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    text-align: center;
    gap: 1rem 0.5rem;
  }

  .stat-cell {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .stat-value {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .stat-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-dark-grey);
  }

  /* ---------- Leaders table ---------- */
  .leaders-table {
    width: 100%;
    border-collapse: collapse;
  }

  .leaders-table tr + tr {
    border-top: 1px solid var(--color-light-grey);
  }

  :where(.dark) .leaders-table tr + tr {
    border-color: #333;
  }

  .leaders-table td {
    padding: 0.45rem 0;
  }

  .leader-cat {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #5D1725;
    width: 3.5rem;
  }

  :where(.dark) .leader-cat {
    color: #c45068;
  }

  .leader-name {
    font-size: 0.95rem;
    color: var(--color-text);
  }

  .leader-val {
    font-size: 1.1rem;
    font-weight: 700;
    text-align: right;
    color: var(--color-text);
  }
</style>

<script>
  /**
   * Fetches hitting, pitching, and SEC standings JSON, then populates the
   * dashboard cards. The record comes from the standings JSON (secsports.com)
   * because it reflects the most current game results.
   */
  async function loadDashboard() {
    try {
      const [hitRes, pitRes, standingsRes, schedRes] = await Promise.all([
        fetch('/data/hitting-stats-2026.json'),
        fetch('/data/pitching-stats-2026.json'),
        fetch('/data/sec-standings-2026.json'),
        fetch('/data/schedule-2026.json'),
      ]);

      if (!hitRes.ok || !pitRes.ok || !standingsRes.ok || !schedRes.ok) throw new Error('Failed to fetch stats data');

      const hitting  = await hitRes.json();
      const pitching = await pitRes.json();
      const standings = await standingsRes.json();
      const schedule = await schedRes.json();

      /* ---- Last updated (match Batting page format) ---- */
      const updatedEl = document.getElementById('last-updated');
      if (updatedEl && hitting.gamesScraped && hitting.lastGame) {
        updatedEl.textContent =
          `Data current through ${hitting.gamesScraped} games, up to the ${hitting.lastGame.date} game vs ${hitting.lastGame.opponent}`;
      }

      /* ---- Next Game card ---- */
      // Find the first scheduled game with no result (i.e., not yet played).
      const nextGame = (schedule.games || []).find((g: any) => !g.result);
      if (nextGame) {
        setText('next-date', nextGame.date || '--');
        setText('next-opponent', nextGame.opponent || '--');
        setText('next-location', nextGame.location || '--');
      } else {
        setText('next-date', 'Season complete');
        setText('next-opponent', 'Season complete');
        setText('next-location', 'Season complete');
      }

      /* ---- Helpers ---- */
      const col = (columns: string[], name: string) => columns.indexOf(name);

      /* ---- Record (from SEC standings JSON — most current source) ---- */
      const msuRow = standings.teams.find(
        (t: string[]) => t[0].toLowerCase().includes('mississippi state')
      );
      if (msuRow) {
        const overallIdx = standings.columns.indexOf('Overall W-L');
        const confIdx    = standings.columns.indexOf('Conf W-L');
        setText('record-overall', msuRow[overallIdx] ?? '--');
        setText('record-sec',     msuRow[confIdx]    ?? '--');
      }

      /* ---- Team Hitting (6 stats) ---- */
      const hitCols = hitting.all.columns;
      const hitSummary = hitting.all.summary[0];
      setText('hit-avg', hitSummary[col(hitCols, 'AVG')]);
      setText('hit-obp', hitSummary[col(hitCols, 'OBP')]);
      setText('hit-slg', hitSummary[col(hitCols, 'SLG')]);
      setText('hit-hr',  hitSummary[col(hitCols, 'HR')]);
      setText('hit-sb',  hitSummary[col(hitCols, 'SB-ATT')]);

      // Runs per game = R / gamesScraped
      const runs = parseInt(hitSummary[col(hitCols, 'R')], 10) || 0;
      const games = hitting.gamesScraped || 1;
      setText('hit-rpg', (runs / games).toFixed(1));

      /* ---- Team Pitching (6 stats) ---- */
      const pitCols = pitching.all.columns;
      const pitSummary = pitching.all.summary[0];
      setText('pit-era',  pitSummary[col(pitCols, 'ERA')]);
      setText('pit-whip', pitSummary[col(pitCols, 'WHIP')]);
      setText('pit-kbb',  pitSummary[col(pitCols, 'K%-BB%')]);
      setText('pit-opp-avg', pitSummary[col(pitCols, 'AVG')]);

      // Compute Opp OBP = (H + BB + HBP) / (AB + BB + HBP + SFA)
      const pH  = parseInt(pitSummary[col(pitCols, 'H')], 10) || 0;
      const pBB = parseInt(pitSummary[col(pitCols, 'BB')], 10) || 0;
      const pHBP = parseInt(pitSummary[col(pitCols, 'HBP')], 10) || 0;
      const pAB  = parseInt(pitSummary[col(pitCols, 'AB')], 10) || 0;
      const pSFA = parseInt(pitSummary[col(pitCols, 'SFA')], 10) || 0;
      const oppOBP = (pH + pBB + pHBP) / (pAB + pBB + pHBP + pSFA);
      setText('pit-opp-obp', isNaN(oppOBP) ? '--' : '.' + oppOBP.toFixed(3).slice(2));

      // Compute Opp SLG = ((1B) + 2*2B + 3*3B + 4*HR) / AB
      const p2B = parseInt(pitSummary[col(pitCols, '2B')], 10) || 0;
      const p3B = parseInt(pitSummary[col(pitCols, '3B')], 10) || 0;
      const pHR = parseInt(pitSummary[col(pitCols, 'HR')], 10) || 0;
      const singles = pH - p2B - p3B - pHR;
      const oppSLG = (singles + 2 * p2B + 3 * p3B + 4 * pHR) / pAB;
      setText('pit-opp-slg', isNaN(oppSLG) ? '--' : '.' + oppSLG.toFixed(3).slice(2));

      /* ---- Batting Leaders (6 rows) ---- */
      const hitters = hitting.all.players;

      // AVG leader
      const avgIdx = col(hitCols, 'AVG');
      const avgLeader = findMax(hitters, avgIdx, parseFloatSafe);
      setText('bldr-avg-name', avgLeader.name);
      setText('bldr-avg-val', hitters.find((p: string[]) => p[0] === avgLeader.name)?.[avgIdx] ?? '--');

      // OBP leader
      const obpIdx = col(hitCols, 'OBP');
      const obpLeader = findMax(hitters, obpIdx, parseFloatSafe);
      setText('bldr-obp-name', obpLeader.name);
      setText('bldr-obp-val', hitters.find((p: string[]) => p[0] === obpLeader.name)?.[obpIdx] ?? '--');

      // SLG leader
      const slgIdx = col(hitCols, 'SLG');
      const slgLeader = findMax(hitters, slgIdx, parseFloatSafe);
      setText('bldr-slg-name', slgLeader.name);
      setText('bldr-slg-val', hitters.find((p: string[]) => p[0] === slgLeader.name)?.[slgIdx] ?? '--');

      // R leader
      const rIdx = col(hitCols, 'R');
      const rLeader = findMax(hitters, rIdx, parseIntSafe);
      setText('bldr-r-name', rLeader.name);
      setText('bldr-r-val', String(rLeader.value));

      // HR leader
      const hrIdx = col(hitCols, 'HR');
      const hrLeader = findMax(hitters, hrIdx, parseIntSafe);
      setText('bldr-hr-name', hrLeader.name);
      setText('bldr-hr-val', String(hrLeader.value));

      // SB leader — format is "SB-ATT", e.g. "10-12"; sort by SB (first number)
      const sbIdx = col(hitCols, 'SB-ATT');
      const sbLeader = findMax(hitters, sbIdx, (v: string) => {
        const parts = v.split('-');
        return parseInt(parts[0], 10) || 0;
      });
      setText('bldr-sb-name', sbLeader.name);
      setText('bldr-sb-val', String(sbLeader.value));

      /* ---- Pitching Leaders (6 rows) ---- */
      const pitchers = pitching.all.players;
      const ipIdx = col(pitCols, 'IP');

      // Filter pitchers with >= 10.0 IP for rate stats
      const qualifiedPitchers = pitchers.filter(
        (p: string[]) => parseFloatSafe(p[ipIdx]) >= 10.0
      );

      // IP leader (all pitchers)
      const ipLeader = findMax(pitchers, ipIdx, parseFloatSafe);
      setText('pldr-ip-name', ipLeader.name);
      setText('pldr-ip-val', pitchers.find((p: string[]) => p[0] === ipLeader.name)?.[ipIdx] ?? '--');

      // K-BB% leader (min 10 IP)
      const kbbIdx = col(pitCols, 'K%-BB%');
      const kbbLeader = findMax(qualifiedPitchers, kbbIdx, (v: string) => parseFloat(v.replace('%', '')) || 0);
      setText('pldr-kbb-name', kbbLeader.name);
      setText('pldr-kbb-val', qualifiedPitchers.find((p: string[]) => p[0] === kbbLeader.name)?.[kbbIdx] ?? '--');

      // K leader (all pitchers)
      const soIdx = col(pitCols, 'SO');
      const kLeader = findMax(pitchers, soIdx, parseIntSafe);
      setText('pldr-k-name', kLeader.name);
      setText('pldr-k-val', String(kLeader.value));

      // WHIP leader (min 10 IP — lowest is best)
      const whipIdx = col(pitCols, 'WHIP');
      const whipLeader = findMin(qualifiedPitchers, whipIdx, parseFloatSafe);
      setText('pldr-whip-name', whipLeader.name);
      setText('pldr-whip-val', qualifiedPitchers.find((p: string[]) => p[0] === whipLeader.name)?.[whipIdx] ?? '--');

      // ERA leader (min 10 IP — lowest is best)
      const eraIdx = col(pitCols, 'ERA');
      const eraLeader = findMin(qualifiedPitchers, eraIdx, parseFloatSafe);
      setText('pldr-era-name', eraLeader.name);
      setText('pldr-era-val', qualifiedPitchers.find((p: string[]) => p[0] === eraLeader.name)?.[eraIdx] ?? '--');

      // FIP leader (min 10 IP — lowest is best)
      const fipIdx = col(pitCols, 'FIP');
      const fipLeader = findMin(qualifiedPitchers, fipIdx, parseFloatSafe);
      setText('pldr-fip-name', fipLeader.name);
      setText('pldr-fip-val', qualifiedPitchers.find((p: string[]) => p[0] === fipLeader.name)?.[fipIdx] ?? '--');

    } catch (err) {
      console.error('Dashboard load error:', err);
      const updatedEl = document.getElementById('last-updated');
      if (updatedEl) updatedEl.textContent = 'Unable to load dashboard data.';
    }
  }

  /** Set text content of an element by ID. */
  function setText(id: string, text: string) {
    const el = document.getElementById(id);
    if (el) el.textContent = text;
  }

  /** Parse an integer string, returning 0 for anything non-numeric. */
  function parseIntSafe(v: string): number {
    return parseInt(v, 10) || 0;
  }

  /** Parse a float string, returning 0 for anything non-numeric. */
  function parseFloatSafe(v: string): number {
    return parseFloat(v) || 0;
  }

  /**
   * Find the player with the max value in a given column.
   * parser converts the string cell value to a number for comparison.
   */
  function findMax(
    players: string[][],
    colIdx: number,
    parser: (v: string) => number,
  ): { name: string; value: number } {
    let bestName = '--';
    let bestVal = -Infinity;

    for (const row of players) {
      const parsed = parser(row[colIdx]);
      if (parsed > bestVal) {
        bestVal = parsed;
        bestName = row[0];
      }
    }

    return { name: bestName, value: bestVal === -Infinity ? 0 : bestVal };
  }

  /**
   * Find the player with the min value in a given column.
   * parser converts the string cell value to a number for comparison.
   * Skips zero/non-positive values (avoids pitchers with 0.00 ERA on few IP).
   */
  function findMin(
    players: string[][],
    colIdx: number,
    parser: (v: string) => number,
  ): { name: string; value: number } {
    let bestName = '--';
    let bestVal = Infinity;

    for (const row of players) {
      const parsed = parser(row[colIdx]);
      if (parsed > 0 && parsed < bestVal) {
        bestVal = parsed;
        bestName = row[0];
      }
    }

    return { name: bestName, value: bestVal === Infinity ? 0 : bestVal };
  }

  loadDashboard();
</script>
