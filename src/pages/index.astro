---
/**
 * Home/landing page for msubaseballstats.com.
 *
 * Displays a hub with cards linking to each stats section.
 * The last-updated date is read dynamically from the hitting stats JSON
 * at build time so it always reflects the most recent data scrape.
 */
import Layout from '../layouts/Layout.astro';

// Read last-updated info from the hitting stats JSON at build time using fs.
// fetch() doesn't work for local files in Astro's build pipeline.
import { readFileSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import path from 'node:path';

let lastUpdated = '';
let gamesScraped = 0;
let lastGame = { date: '', opponent: '' };
try {
  const dir = path.dirname(fileURLToPath(import.meta.url));
  const jsonPath = path.resolve(dir, '../../public/data/hitting-stats-2026.json');
  const data = JSON.parse(readFileSync(jsonPath, 'utf-8'));
  lastUpdated = data.lastUpdated ?? '';
  gamesScraped = data.gamesScraped ?? 0;
  lastGame = data.lastGame ?? { date: '', opponent: '' };
} catch {
  // silently ignore if file is missing
}

/**
 * Format an ISO timestamp like "2026-04-12T03:06:31" into "April 12, 2026".
 */
function formatDate(iso: string): string {
  if (!iso) return '';
  const d = new Date(iso + 'Z'); // treat as UTC
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
}

const formattedDate = formatDate(lastUpdated);

/** Each card on the landing page */
interface StatCard {
  href: string;
  title: string;
  description: string;
  external?: boolean;
}

const cards: StatCard[] = [
  {
    href: '/batting-2026',
    title: 'Hitting Stats',
    description: 'Season batting totals and advanced metrics — AVG, OBP, SLG, ISO, BABIP and more. Filter by All / SEC / Non-Conference.',
  },
  {
    href: '/pitching-2026',
    title: 'Pitching Stats',
    description: 'ERA, WHIP, K/9, BB/9, FIP, and standard pitching lines for every pitcher on the roster.',
  },
  {
    href: '/fielding-2026',
    title: 'Fielding Stats',
    description: 'Defensive statistics including putouts, assists, errors, fielding percentage, and double plays.',
  },
  {
    href: '/situational-hitting-2026',
    title: 'Situational Hitting',
    description: 'Batting splits by game situation — home/away, by inning, with runners on base, and more.',
  },
  {
    href: '/situational-pitching-2026',
    title: 'Situational Pitching',
    description: 'Pitching splits by situation — home/away, by inning, with runners on base, and more.',
  },
  {
    href: '/batter-splits-2026',
    title: 'Batter Splits Selector',
    description: 'Advanced batter splits with 6 independent filters: pitcher hand, location, opponent type, count, baserunners, and leverage.',
  },
  {
    href: '/pitcher-splits-2026',
    title: 'Pitcher Splits Selector',
    description: 'Advanced pitcher splits with 6 independent filters: batter hand, location, opponent type, count, baserunners, and leverage.',
  },
  {
    href: 'https://diamond-dawg-tracker.streamlit.app/',
    title: 'Diamond Dawg Tracker',
    description: 'Interactive game-by-game tracker with play-by-play detail and win probability.',
    external: true,
  },
  {
    href: '/amegy-batters-2026',
    title: 'Amegy Series — Batters',
    description: 'Individual batter summaries from the 2026 Amegy Bank Series.',
  },
  {
    href: '/amegy-pitchers-2026',
    title: 'Amegy Series — Pitchers',
    description: 'Individual pitcher summaries from the 2026 Amegy Bank Series.',
  },
];
---

<Layout title="Home" description="Mississippi State Baseball Statistics — advanced stats, splits, and situational analysis for the 2026 season.">

  <!-- Hero banner -->
  <div
    class="rounded-xl px-8 py-10 mb-10 text-white"
    style="background-color: #5D1725;"
  >
    <h1 class="text-3xl font-bold mb-2" style="color: #ffffff;">
      Mississippi State Baseball
    </h1>
    <p class="text-lg mb-4" style="color: #C1C6C8;">
      Advanced statistics and splits for the 2026 season
    </p>
    {formattedDate && (
      <p class="text-sm" style="color: #C1C6C8;">
        Last updated: <strong style="color: #ffffff;">{formattedDate}</strong>
        &nbsp;&mdash;&nbsp;
        <strong style="color: #ffffff;">{gamesScraped}</strong> games scraped
        &nbsp;&mdash;&nbsp;
        Most recent: <strong style="color: #ffffff;">{lastGame.opponent}</strong> ({lastGame.date})
      </p>
    )}
  </div>

  <!-- Stats cards grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
    {cards.map((card) => (
      <a
        href={card.href}
        target={card.external ? '_blank' : undefined}
        rel={card.external ? 'noopener noreferrer' : undefined}
        class="block rounded-xl p-5 transition-all hover:shadow-md"
        style="text-decoration: none; border: 1px solid #C1C6C8; background-color: var(--color-bg);"
        onmouseover="this.style.borderColor='#5D1725'; this.style.boxShadow='0 4px 12px rgba(93,23,37,0.15)';"
        onmouseout="this.style.borderColor='#C1C6C8'; this.style.boxShadow='';"
      >
        <div class="flex items-start justify-between gap-2 mb-2">
          <h2 class="text-base font-semibold" style="color: #5D1725;">
            {card.title}
          </h2>
          {card.external && (
            <!-- External link icon -->
            <svg class="w-4 h-4 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" style="color: #777777;">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          )}
        </div>
        <p class="text-sm leading-relaxed" style="color: #777777;">
          {card.description}
        </p>
      </a>
    ))}
  </div>

  <!-- Data credit -->
  <p class="mt-10 text-xs text-center" style="color: #777777;">
    Statistics sourced from the
    <a href="https://stats.ncaa.org/teams/614666" target="_blank" rel="noopener noreferrer" style="color: #5D1725;">
      NCAA Stats portal
    </a>
    &nbsp;(Mississippi State — Team ID 614666)
  </p>

</Layout>
