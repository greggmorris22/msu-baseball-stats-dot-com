---
/**
 * About page for msubaseballstats.com.
 */
import Layout from '../layouts/Layout.astro';
---

<Layout title="About" description="About msubaseballstats.com — the best free online resource for Mississippi State baseball statistics.">

  <div class="max-w-2xl mx-auto py-8">
    <h1 class="text-3xl font-bold mb-6" style="color: #5D1725;">About</h1>

    <div class="text-lg leading-relaxed" style="color: var(--color-text);">
      <p class="mb-4">
        The name says what it is. My goal is for msubaseballstats.com to be the BEST available
        online resource for Mississippi State University baseball team statistics that just happens
        to also be FREE. This website is currently a work-in-progress. Feel free to
        <a href="mailto:greggmorris22@gmail.com" style="color: #5D1725; text-decoration: underline;">contact me</a>
        and provide any feedback you have or features you'd like to see. Not affiliated with
        Mississippi State University.
      </p>

      <p class="mt-8" style="color: #777777;">
        - Gregg Morris
      </p>
    </div>
  </div>

</Layout>
