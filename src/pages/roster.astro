---
/**
 * MSU Baseball — Roster
 *
 * Loads the pre-scraped roster data from public/data/roster-2026.json,
 * which is produced by scripts/scrape-roster.py (a one-time scrape of
 * stats.ncaa.org). Displays all players in a styled table sorted by
 * jersey number.
 *
 * To refresh data: .venv/Scripts/python.exe scripts/scrape-roster.py
 */
import Layout from '../layouts/Layout.astro';
---

<Layout title="Roster" description="Mississippi State baseball 2026 roster.">

  <h1 class="text-3xl font-bold mb-2">Roster</h1>
  <p id="roster-subtitle" class="text-stone-500 dark:text-stone-400 mb-4 text-lg">
    Mississippi State Bulldog baseball.
  </p>

  <div class="rounded-xl border border-stone-200 dark:border-stone-700 overflow-hidden bg-white dark:bg-stone-800 shadow-sm">
    <div id="roster-container" class="p-4 text-sm text-stone-500 dark:text-stone-400">
      Loading roster&hellip;
    </div>
  </div>

</Layout>

<style is:global>
  /* ===== BASE TABLE ===== */
  .roster-wrapper { overflow-x: auto; }

  .roster-table {
    width: 100%;
    font-size: 0.8125rem;
    border-collapse: separate;
    border-spacing: 0;
    white-space: nowrap;
  }

  /* ===== COLUMN HEADER ROW ===== */
  .roster-table thead th {
    background-color: #5D1725;
    color: #ffffff;
    padding: 0.55rem 0.75rem;
    text-align: left;
    font-weight: 600;
    letter-spacing: 0.03em;
    border-bottom: 2px solid #4a1020;
  }

  /* ===== SORTABLE HEADERS ===== */
  .roster-table th.sortable {
    cursor: pointer;
    user-select: none;
    transition: background-color 0.15s;
  }

  .roster-table th.sortable:hover {
    background-color: #7a1f30;
  }

  .roster-table .sort-arrow {
    display: inline-block;
    margin-left: 3px;
    font-size: 0.6rem;
    vertical-align: middle;
    opacity: 0.85;
  }

  .dark .roster-table th.sortable:hover {
    background-color: #93253b;
  }

  /* ===== DATA CELLS ===== */
  .roster-table tbody td {
    padding: 0.4rem 0.75rem;
    border-bottom: 1px solid rgb(245 245 244);
    color: rgb(41 37 36);
  }

  /* Alternating row stripe */
  .roster-table tbody tr:nth-child(odd) td {
    background-color: rgb(255 255 255);
  }

  .roster-table tbody tr:nth-child(even) td {
    background-color: rgb(250 250 249);
  }

  /* Row hover highlight */
  .roster-table tbody tr:hover td {
    background-color: rgb(245 245 244);
  }

  /* ===== COLUMN WIDTHS ===== */
  /* Jersey number — narrow */
  .roster-table td.col-num,
  .roster-table th.col-num {
    text-align: center;
    width: 2.5rem;
  }

  /* Name — wider */
  .roster-table td.col-name {
    font-weight: 500;
  }

  /* ===== DARK MODE ===== */
  .dark .roster-table thead th {
    background-color: #7a1f30;
    border-bottom-color: #5D1725;
  }

  .dark .roster-table tbody td {
    color: rgb(214 211 209);
    border-bottom-color: rgb(41 37 36);
  }

  .dark .roster-table tbody tr:nth-child(odd) td {
    background-color: rgb(41 37 36);
  }

  .dark .roster-table tbody tr:nth-child(even) td {
    background-color: rgb(35 31 30);
  }

  .dark .roster-table tbody tr:hover td {
    background-color: rgb(50 46 44);
  }

  /* ===== LAST-UPDATED NOTE ===== */
  .roster-updated {
    font-size: 0.75rem;
    color: rgb(120 113 108);
    text-align: right;
    padding: 0.4rem 0.75rem 0.5rem;
  }

  .dark .roster-updated {
    color: rgb(87 83 78);
  }
</style>

<script>
  // ===========================================================================
  // State
  // ===========================================================================

  let columns    = [];   // column header labels from JSON
  let playerRows = [];   // all player rows (arrays of cell strings)
  let sortCol    = -1;   // index of currently sorted column (-1 = default)
  let sortAsc    = true; // true = ascending, false = descending
  let scrapedStr = '';   // formatted scrape date
  let sourceUrl  = '';   // NCAA source URL

  // ===========================================================================
  // Helpers
  // ===========================================================================

  /**
   * Try to parse a cell value as a number. Returns null if not numeric.
   * Handles jersey numbers, heights like "6-3" (converts to inches for
   * comparison), and plain integers/floats.
   */
  function parseNum(str) {
    if (!str || str.trim() === '') return null;
    const s = str.trim();
    // Heights like "6-3" → convert to total inches for numeric comparison
    const htMatch = s.match(/^(\d+)-(\d+)$/);
    if (htMatch) return parseInt(htMatch[1]) * 12 + parseInt(htMatch[2]);
    const num = parseFloat(s);
    return isNaN(num) ? null : num;
  }

  /** Compare two data rows by the current sort column. */
  function compareRows(a, b) {
    const va = parseNum(a[sortCol]);
    const vb = parseNum(b[sortCol]);

    // Both numeric — compare numerically
    if (va !== null && vb !== null) {
      const diff = va - vb;
      return sortAsc ? diff : -diff;
    }
    // Push non-numeric / empty values to the bottom
    if (va === null && vb === null) {
      // Fall back to string comparison for text columns
      const sa = (a[sortCol] || '').toLowerCase();
      const sb = (b[sortCol] || '').toLowerCase();
      const cmp = sa.localeCompare(sb);
      return sortAsc ? cmp : -cmp;
    }
    if (va === null) return 1;
    if (vb === null) return -1;
    return 0;
  }

  // ===========================================================================
  // Render
  // ===========================================================================

  function render() {
    const container = document.getElementById('roster-container');
    if (!container) return;

    const sorted = sortCol >= 0
      ? [...playerRows].sort(compareRows)
      : [...playerRows];

    // --- Wrapper ---
    const wrapper = document.createElement('div');
    wrapper.className = 'roster-wrapper';

    const table = document.createElement('table');
    table.className = 'roster-table';

    // --- THEAD ---
    const thead = document.createElement('thead');
    const headerTr = document.createElement('tr');

    columns.forEach((label, i) => {
      const th = document.createElement('th');
      th.textContent = label;

      // All columns are sortable
      th.classList.add('sortable');
      if (label === '#') th.classList.add('col-num');

      if (sortCol === i) {
        const arrow = document.createElement('span');
        arrow.className = 'sort-arrow';
        arrow.textContent = sortAsc ? '\u25B2' : '\u25BC';
        th.appendChild(arrow);
      }

      th.addEventListener('click', () => handleSort(i));
      headerTr.appendChild(th);
    });

    thead.appendChild(headerTr);
    table.appendChild(thead);

    // --- TBODY ---
    const tbody = document.createElement('tbody');
    sorted.forEach(row => {
      const tr = document.createElement('tr');
      columns.forEach((col, i) => {
        const td = document.createElement('td');
        td.textContent = row[i] ?? '';
        if (col === '#') td.classList.add('col-num');
        if (col === 'Name') td.classList.add('col-name');
        tr.appendChild(td);
      });
      tbody.appendChild(tr);
    });
    table.appendChild(tbody);

    // --- Footer note ---
    const note = document.createElement('p');
    note.className = 'roster-updated';
    note.innerHTML = `Source: <a href="${sourceUrl}" target="_blank" rel="noopener noreferrer"
      class="underline hover:text-stone-700 dark:hover:text-stone-300">stats.ncaa.org</a>
      &nbsp;&middot;&nbsp; Scraped ${scrapedStr}`;

    wrapper.appendChild(table);
    container.replaceChildren(wrapper, note);
  }

  // ===========================================================================
  // Sort handler
  // ===========================================================================

  function handleSort(colIdx) {
    if (sortCol === colIdx) {
      sortAsc = !sortAsc;             // same column → toggle direction
    } else {
      sortCol = colIdx;
      // Default direction: ascending for text columns, ascending for # too
      sortAsc = true;
    }
    render();
  }

  // ===========================================================================
  // Load data and initialise
  // ===========================================================================

  async function init() {
    const container = document.getElementById('roster-container');
    const subtitle  = document.getElementById('roster-subtitle');

    try {
      const res = await fetch('/data/roster-2026.json');
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();

      columns    = data.columns || [];
      playerRows = data.players || [];
      sourceUrl  = data.source || '';

      scrapedStr = data.scraped
        ? new Date(data.scraped).toLocaleDateString('en-US', {
            year: 'numeric', month: 'long', day: 'numeric',
          })
        : 'unknown date';

      subtitle.textContent = `Mississippi State Bulldog baseball \u2022 ${playerRows.length} players`;

      // Default sort: jersey number ascending
      const numIdx = columns.indexOf('#');
      if (numIdx >= 0) {
        sortCol = numIdx;
        sortAsc = true;
      }

      render();
    } catch (err) {
      container.innerHTML = `
        <p class="text-red-600 dark:text-red-400 font-medium">
          Failed to load roster data: ${err.message}
        </p>
        <p class="mt-1 text-xs">
          Run <code>scripts/scrape-roster.py</code> to generate the data file.
        </p>
      `;
    }
  }

  init();
</script>
